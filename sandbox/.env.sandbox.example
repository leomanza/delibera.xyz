# IronClaw sandbox workspace (dev-only — no real keys)
# Copy to .env.sandbox and fill in NEAR_AI_API_KEY, ENSUE_API_KEY, ENSUE_COORDINATOR_ORG
# Note: IronClaw v0.28.1 always uses ~/.ironclaw — IRONCLAW_HOME env var is ignored

# Webhook
HTTP_ENABLED=true
HTTP_HOST=127.0.0.1
HTTP_PORT=8080
HTTP_WEBHOOK_SECRET=sandbox-secret

# Heartbeat (fast for dev iteration)
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SECS=10
SELF_REPAIR_ENABLED=true

# Worker identity (fake — sandbox only)
WORKER_DID=did:key:sandbox-worker-1
WORKER_NEAR_ACCOUNT=sandbox-worker.testnet
ENSUE_API_KEY=<your-dev-ensue-key>
ENSUE_COORDINATOR_ORG=<your-coordinator-org>

# LLM — use real key to test actual deliberation
NEAR_AI_API_KEY=<your-near-ai-key>
