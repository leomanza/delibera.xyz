# Docker Compose env for Step 5.6 (3 IronClaw workers + Ensue MCP).
# Copy to docker/.env and fill in. Source it before running docker compose:
#   set -a && source docker/.env && set +a && docker compose -f docker/docker-compose.yml up

# Shared across all 3 worker containers
ENSUE_API_KEY=<paste-your-ensue-key>
ENSUE_COORDINATOR_ORG=delibera_coordinator   # or your actual Ensue org name
HTTP_WEBHOOK_SECRET=sandbox-secret           # MUST match coordinator's IRONCLAW_WEBHOOK_SECRET
NEAR_AI_API_KEY=<paste-your-near-ai-key>

# Optional: override the IronClaw LLM model
# IRONCLAW_MODEL=Qwen/Qwen3.5-122B-A10B
