# Docker image for the standalone Ensue MCP server.
# (Note: in the Delibera Docker compose, the MCP server is bundled INSIDE each
# worker container — see Dockerfile.delibera-worker — to bypass IronClaw's
# HTTPS-required policy for non-loopback MCP URLs. This image is kept for
# standalone use cases like Claude Desktop or external MCP clients.)
#
# Build (from repo root):
#   docker build -f docker/Dockerfile.delibera-mcp -t delibera-mcp .

FROM node:20-bookworm-slim

WORKDIR /opt/mcp

# Copy the ensue-client package (the MCP server depends on it via file:../ensue-client)
COPY ensue-client/package.json /opt/ensue-client/package.json
COPY ensue-client/dist/ /opt/ensue-client/dist/

# Copy MCP server source
COPY ensue-mcp-server/package.json /opt/mcp/package.json
COPY ensue-mcp-server/dist/ /opt/mcp/dist/

# Install only prod deps. The workspace dep `@delibera-xyz/ensue-client`
# is resolved via the local path (file:../ensue-client).
RUN npm install --omit=dev --omit=optional 2>&1 | tail -5

EXPOSE 7800

ENV PORT=7800
ENV HOST=0.0.0.0

CMD ["node", "/opt/mcp/dist/index.js"]
