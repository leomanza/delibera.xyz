# Delibera x402 Client — Environment Variables
#
# Copy this file to .env and fill in your own values:
#   cp .env.example .env

# Stellar testnet secret key (S...) that will PAY for deliberations.
# Requirements:
#   1. Fund the underlying public key with testnet XLM via friendbot:
#      curl "https://friendbot.stellar.org?addr=YOUR_PUBLIC_KEY"
#   2. Add a USDC trustline (see README or use Stellar Lab)
#   3. Get testnet USDC from https://faucet.circle.com/ (select Stellar testnet)
# Generate a fresh keypair via:
#   node -e "const { Keypair } = await import('@stellar/stellar-sdk'); const kp = Keypair.random(); console.log(kp.publicKey()); console.log(kp.secret());"
STELLAR_PRIVATE_KEY=

# URL of the Delibera coordinator running the /x402/* routes.
# Default to localhost for local dev — swap for a public host when demoing.
DELIBERA_SERVER_URL=http://localhost:3000

# Optional: the proposal text the client will submit on `pnpm demo`. If unset,
# the client uses a built-in default DAO governance example.
# DELIBERA_PROPOSAL="Should the DAO allocate 50,000 USDC to a developer education program?"

# Optional: number of times to poll /x402/verdict/:id before giving up.
# Each poll costs $0.002 USDC. Default 6 polls × 10s = 60s.
# DELIBERA_MAX_POLLS=6
